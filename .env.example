# PostgreSQL connection string
# Local example:  postgresql://postgres:postgres@localhost:5432/gsm
# Docker example: postgresql://postgres:postgres@localhost:5432/homeflux
# Neon example:   postgresql://USER:PASS@ep-xxxx.aws.neon.tech/gsm?sslmode=require
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/gsm"

# Session signing secret (generate with: openssl rand -base64 32)
AUTH_SECRET="change-me-to-a-long-random-string-please"

# Default admin credentials created by the seed script
ADMIN_EMAIL="admin@globalservicemitra.in"
ADMIN_PASSWORD="Admin@12345"

# In development the OTP code is fixed to this value (no SMS gateway).
# Set to "random" to generate a real 6-digit code printed to the server console.
DEV_OTP_CODE="123456"

# Used for SEO metadata, sitemap and OG URLs
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
